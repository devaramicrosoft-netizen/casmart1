PORT=5000

# Midtrans Keys (dapatkan dari dashboard.midtrans.com → Settings → Access Keys)
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here

# MySQL Database (default Laragon)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=casmart_db

# JWT Secret (ganti dengan string acak yang panjang di production!)
JWT_SECRET=casmart_jwt_secret_ganti_ini_di_production-YWlXYyDO4qZBW5At

# Gemini API Key (Untuk Chatbot)
GEMINI_API_KEY=your_gemini_api_key_here
